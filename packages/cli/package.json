{
  "name": "@oppgaveretter/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "CLI for å sende inn løsninger og publisere oppgaver til oppgaveretteren.",
  "bin": {
    "oppgaveretter": "dist/index.js"
  },
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@oppgaveretter/protocol": "*",
    "tsup": "^8.0.0"
  }
}
